# Copy to .env and fill in to enable the weekly email notifier (src/notify.py).
# .env is gitignored — never commit real credentials.

# Optional: raises the BLS public-API rate limit (the pipeline works without it).
BLS_API_KEY=

# SMTP settings for the regime-change email. For Gmail, use an App Password
# (Google Account -> Security -> App passwords), NOT your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password
NOTIFY_TO=your_address@gmail.com
